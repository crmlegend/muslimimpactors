# Local dev uses SQLite so the CMS can run without Docker/Postgres.
DATABASE_URL=file:./payload.db

# Supabase/production can switch to Postgres:
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/muslim_impactors

PAYLOAD_SECRET=YOUR_SECRET_HERE
NEXT_PUBLIC_SITE_URL=https://muslimimpactors.americanmotivations.com

# Supabase Postgres requires SSL in production.
# This is automatic for supabase.com URLs; set explicitly for other managed Postgres providers if needed.
# DATABASE_SSL=true

# Existing local SQLite databases should avoid automatic schema push. Set true only for a fresh DB.
# PAYLOAD_SQLITE_PUSH=true

# First production launch only: lets Payload create the initial Postgres schema.
# Keep false/remove after schema is stable.
PAYLOAD_POSTGRES_PUSH=false
